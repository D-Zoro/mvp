# Books4All Backend Configuration
# Copy this file to .env and fill in with your own values
# NEVER commit .env with real credentials to git
# Use this file as a template for environment setup

# ─────────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=Books4All
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────────────────────

API_V1_PREFIX=/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection URL (async driver)
# Format: postgresql+asyncpg://username:password@hostname:port/database
# IMPORTANT: Never hardcode passwords — use environment variables
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/books4all_dev

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ─────────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password_if_required

# ─────────────────────────────────────────────────────────────────────────────
# JWT Security (CRITICAL)
# ─────────────────────────────────────────────────────────────────────────────

# Secret key for JWT signing — MUST be at least 32 characters
# Generate with: openssl rand -hex 32
# IMPORTANT: Change this in production immediately
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# Password Hashing
# ─────────────────────────────────────────────────────────────────────────────

BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ─────────────────────────────────────────────────────────────────────────────
# OAuth Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_CALLS=100
RATE_LIMIT_DEFAULT_PERIOD=60
RATE_LIMIT_LOGIN_CALLS=5
RATE_LIMIT_LOGIN_PERIOD=900

# ─────────────────────────────────────────────────────────────────────────────
# File Upload Configuration
# ─────────────────────────────────────────────────────────────────────────────

MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Payment Processing (CRITICAL)
# ─────────────────────────────────────────────────────────────────────────────

# Get API keys from: https://dashboard.stripe.com/apikeys
# Secret key: starts with sk_live_ (production) or sk_test_ (development)
# IMPORTANT: Never use sk_test_ keys in production
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# Publishable key: starts with pk_live_ (production) or pk_test_ (development)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Webhook secret from: https://dashboard.stripe.com/webhooks
# Format: whsec_*
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# AWS Configuration (Optional for S3/MinIO storage)
# ─────────────────────────────────────────────────────────────────────────────

# Get credentials from: https://console.aws.amazon.com/iam/
# Access Key ID: AKIA* format
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here

# Secret Access Key: generated with Access Key ID
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here

# AWS region for S3/storage operations
AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ─────────────────────────────────────────────────────────────────────────────

FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Security Notes
# ─────────────────────────────────────────────────────────────────────────────

# CRITICAL REMINDERS:
# 1. Never commit .env file to git (it's in .gitignore)
# 2. Always use strong, unique values for all secrets
# 3. Rotate secrets regularly in production
# 4. Use a secrets management system (e.g., AWS Secrets Manager, Vault) in production
# 5. Validate all secrets at application startup
# 6. Monitor secret rotation and expiration
# 7. Use different credentials for each environment (dev/staging/production)
# 8. Audit access to secrets and credential logs
